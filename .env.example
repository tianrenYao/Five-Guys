# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DB=sustainability_platform

# Flask Configuration
# - On UCD VM (production): FLASK_DEBUG=False and FLASK_HOST=127.0.0.1
# - For local dev with LAN access: FLASK_HOST=0.0.0.0
FLASK_SECRET_KEY=change-this-to-a-random-string
FLASK_DEBUG=True
FLASK_HOST=127.0.0.1
FLASK_PORT=5001

# Flask-Mail SMTP (leave MAIL_SERVER blank to use mock/log mode)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=noreply@esg-platform.com

# DeepSeek AI (leave blank to use mock AI comments)
DEEPSEEK_API_KEY=
